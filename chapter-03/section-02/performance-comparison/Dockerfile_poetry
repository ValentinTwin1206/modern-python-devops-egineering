FROM python:3.12-slim

# Install poetry
RUN pip install --no-cache-dir poetry && \
    poetry config virtualenvs.create false

ARG PACKAGES=""

WORKDIR /app

RUN poetry init --name benchmark --no-interaction

RUN set -e && \
    START_NS=$(date +%s%N) && \
    poetry add --no-interaction $PACKAGES && \
    END_NS=$(date +%s%N) && \
    ELAPSED_MS=$(( (END_NS - START_NS) / 1000000 )) && \
    printf '{"tool":"poetry","packages":"%s","install_time_ms":%d,"timestamp_ns":%d}\n' \
      "$PACKAGES" "$ELAPSED_MS" "$END_NS" > /tmp/install_metrics.json

CMD ["cat", "/tmp/install_metrics.json"]
