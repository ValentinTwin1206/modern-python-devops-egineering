# DEVELOPMENT IMAGE:
#   - uses continuumio/miniconda3 directly
#   - creates the image-processor env from environment.yml
#   - opens an interactive shell with the conda env activated and dev tools ready
# # # # # # # # # # #
FROM continuumio/miniconda3

ENV CONDA_DIR=/opt/conda \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1
ENV PATH=$CONDA_DIR/bin:$PATH

WORKDIR /app

# Setup the sudo user "snake" and group so the image can be used for development 
# without root privileges.
RUN apt-get update \
    && apt-get install -y --no-install-recommends sudo \
    && rm -rf /var/lib/apt/lists/* \
    && useradd --create-home --shell /bin/bash --groups sudo snake \
    && printf 'snake ALL=(ALL) NOPASSWD:ALL\n' > /etc/sudoers.d/snake \
    && chmod 0440 /etc/sudoers.d/snake

# Accept Anaconda channel terms so the image can build non-interactively.
RUN conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/main \
    && conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/r

# Copy the conda environment definition first to maximize Docker layer caching.
COPY environment.yml ./

# Create the conda environment (pulls OpenCV's native shared libraries from
# conda-forge, which is the whole point of using Conda for this project).
RUN conda env create -f environment.yml \
    && conda clean --all --yes

# Put the env first on PATH so project tools (karva, python) are immediate.
ENV PATH=$CONDA_DIR/envs/image-processor/bin:$PATH
ENV CONDA_DEFAULT_ENV=image-processor

# Copy project files and expose the source tree for live development.
COPY src ./src
COPY tests ./tests
ENV PYTHONPATH=/app/src

# Auto-activate the env for interactive bash shells.
RUN echo 'source /opt/conda/etc/profile.d/conda.sh' >> /home/snake/.bashrc \
    && echo 'conda activate image-processor' >> /home/snake/.bashrc \
    && echo 'cd /app' >> /home/snake/.bashrc \
    && chown -R snake:snake /app /home/snake /opt/conda

USER snake

# Default to an interactive development shell.
CMD ["/bin/bash"]
